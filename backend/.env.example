NODE_ENV=development
PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=hea_database
DB_CONNECTION_LIMIT=10

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h

OTP_ENABLED=true
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# Only for a local academic demo. Never enable in production.
DEMO_OTP=true

CORS_ORIGINS=http://localhost:4000
